ISSUER_URL=https://mcp.example.com
JWT_SECRET=<openssl rand -hex 32>
FREEE_CLIENT_ID=<freee developer console client ID>
FREEE_CLIENT_SECRET=<freee developer console client secret>
REDIS_URL=redis://redis:6379
PORT=3000
LOG_LEVEL=info

# Rate limiting (opt-in; set false if reverse proxy handles it)
RATE_LIMIT_ENABLED=false

# CORS (default: ISSUER_URL only. Multiple origins: comma-separated)
# CORS_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com
